{
  "name": "@effinrich/figma-drift",
  "version": "0.1.0",
  "description": "Bidirectional drift detection and sync between React components and Figma design systems",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "figma-drift": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest --run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "figma",
    "design-system",
    "drift-detection",
    "sync",
    "bidirectional",
    "react",
    "tailwind",
    "storybook",
    "mcp",
    "design-tokens"
  ],
  "author": "Rich Tillman",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/effinrich/figma-drift.git"
  },
  "homepage": "https://github.com/effinrich/figma-drift#readme",
  "bugs": {
    "url": "https://github.com/effinrich/figma-drift/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "culori": "^4.0.1",
    "ts-morph": "^25.0.0"
  },
  "devDependencies": {
    "@fast-check/vitest": "^0.2.0",
    "@types/node": "^22.0.0",
    "fast-check": "^3.23.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "storybook": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "storybook": {
      "optional": true
    }
  }
}
